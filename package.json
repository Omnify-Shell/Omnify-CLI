{
  "name": "omnify-cli",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "omnify": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "dev": "tsup --watch",
    "build": "tsup",
    "start" : "node ./dist/index.js",
    "prepublishOnly": "npm run build",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "inquirer": "^13.4.1",
    "zod": "^4.3.6"
  }
}
